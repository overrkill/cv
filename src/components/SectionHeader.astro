---
interface Props {
  section: string;
  expandable: boolean;
}
const { section, expandable } = Astro.props;
---

<div class="flex items-center gap-4 mb-6">
  <h2 class="text-xl font-semibold text-foreground">{section}</h2>
  <div class="flex-1 border-t border-gray-200 dark:border-gray-800"></div>
  {
    expandable && (
      <a href={`/${section.toLowerCase()}`} class="text-sm text-orange-500 hover:text-orange-600 flex items-center gap-1 font-medium">
        View all
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </a>
    )
  }
</div>
