---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout>
  <section class="pb-8 sm:pb-12">
    <h1 class="text-2xl font-semibold text-foreground mb-8">Writings</h1>
    <div>
      {
        posts.map(post => (
          <a href={`/writings/${post.id}`} class="block border-b border-gray-200 dark:border-gray-800 py-6 group">
            <p class="text-xs text-gray-400 dark:text-gray-500 font-mono mb-1">
              {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
            </p>
            <h2 class="text-lg font-semibold text-foreground group-hover:text-orange-500 mb-1">{post.data.title}</h2>
            <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{post.data.description}</p>
          </a>
        ))
      }
    </div>
  </section>
  <Footer />
</Layout>
