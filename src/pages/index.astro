---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ProjectBox from "../components/ProjectBox.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";

const projects = await getCollection("projects");
projects.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const writings = await getCollection("blog");
writings.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const recentWritings = writings.slice(0, 3);
---

<Layout>
  <Hero />

  <section class="py-8">
    <SectionHeader section="Writings" expandable={true} />
    <div>
      {recentWritings.map(post => (
        <a href={`/writings/${post.id}`} class="block border-b border-gray-200 dark:border-gray-800 py-4 group">
          <p class="text-xs text-gray-400 dark:text-gray-500 font-mono mb-0.5">
            {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
          </p>
          <h3 class="font-semibold text-foreground group-hover:text-orange-500 mb-1">{post.data.title}</h3>
          <p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2 mb-0.5">{post.data.description}</p>
          <span class="text-xs text-orange-500 font-medium">... read more</span>
        </a>
      ))}
    </div>
  </section>

  <section class="pb-8">
    <SectionHeader section="Projects" expandable={true} />
    <div>
      {projects.map(p => (
        <ProjectBox title={p.data.title} description={p.data.description} tags={p.data.tags} github={p.data.github} live={p.data.live} />
      ))}
    </div>
  </section>

  <Footer />
</Layout>
