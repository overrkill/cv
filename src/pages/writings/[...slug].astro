---
import Layout from "../../layouts/Layout.astro";
import { getCollection, getEntry, render } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map(post => ({
    params: { slug: post.id },
  }));
}

const { slug } = Astro.params;
const post = await getEntry("blog", slug);
const { Content } = post ? await render(post).catch(() => ({})) : {};
---

<Layout>
  <article class="py-8 sm:py-12 max-w-2xl">
    <a href="/writings" class="text-sm text-gray-400 dark:text-gray-500 hover:text-orange-500 mb-6 inline-block">&larr; back to writings</a>
    {post && (
      <div>
        <p class="text-xs text-gray-400 dark:text-gray-500 font-mono mb-2">
          {post.data.date.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
        </p>
        <h1 class="text-2xl sm:text-3xl font-semibold text-foreground mb-4">{post.data.title}</h1>
        <p class="text-gray-600 dark:text-gray-400 mb-8">{post.data.description}</p>
        {Content && <Content />}
      </div>
    )}
    {!post && <p class="py-8 text-gray-500 dark:text-gray-400">Post not found.</p>}
  </article>
</Layout>
